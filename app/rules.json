  "sql_injection": {
    "enabled": true,
    "severity": "critical",
    "confidence": 0.85,
    "description": "SQL injection attack patterns including time-based, union-based, and error-based techniques",
    "tags": ["owasp-top10", "injection", "database"],
    "action": "block",
    "patterns": [
      "(<script>)",
      "(union\\s+select)",
      "(union\\s+all\\s+select)",
      "(\\'\\s+or\\s+1\\s*=\\s*1)",
      "(\\\"\\s+or\\s+1\\s*=\\s*1)",
      "(or\\s+1\\s*=\\s*1)",
      "(\\bSELECT\\b.+\\bFROM\\b)",
      "(\\bINSERT\\b.+\\bINTO\\b)",
      "(\\bUPDATE\\b.+\\bSET\\b)",
      "(\\bDELETE\\b.+\\bFROM\\b)",
      "(drop\\s+table)",
      "(;\\s*drop\\b)",
      "(;\\s*shutdown\\b)",
      "(--)",
      "(;--)",
      "(;\\s*$)",
      "(/\\*.*\\*/)",
      "(\\bor\\b.+\\=)",
      "(sleep\\s*\\(\\s*\\d+\\s*\\))",
      "(benchmark\\s*\\()",
      "(waitfor\\s+delay\\s+'?[0-9: ]+'?)",
      "(pg_sleep\\s*\\()",
      "(load_file\\s*\\()",
      "(into\\s+outfile)",
      "(into\\s+dumpfile)",
      "(information_schema\\.)",
      "(@@version)",
      "(@@datadir)",
      "(concat\\s*\\()",
      "(xp_cmdshell)",
      "(exec\\s+xp_)",
      "(sp_executesql)",
      "(execute\\s+immediate)",
      "(sys\\.objects)",
      "0x[0-9a-fA-F]{4,}",
      "(char\\s*\\()",
      "((%27)|(%22)|(')|(\\\"))\\s*or\\s*?\\b",
      "(\\bcase\\b.+\\bwhen\\b.+\\bthen\\b)",
      "(\\b1\\s*=\\s*1\\b)",
      "(\\b'1'='1'\\b)",
      "(\\b\"1\"=\"1\"\\b)",
      "(\\btrue\\s*--)",
      "(union(.|\\s)*?select)",
      "(select(.|\\s)*?from(.|\\s)*?information_schema)",
      "(sleep\\s*\\()",
      "(\\bOR\\b\\s+\\d+\\s*=\\s*\\d+)",
      "(\\bAND\\b\\s+['\"]?\\d+['\"]?\\s*=\\s*['\"]?\\d+['\"]?)",
      "(\\band\\b\\s+['\"]?\\d+['\"]?\\s*=\\s*['\"]?\\d+['\"]?)",
      "(\\bWAITFOR\\b)",
      "(\\bCAST\\b\\s*\\()",
      "(\\bCONVERT\\b\\s*\\()",
      "(\\bHAVING\\b\\s+\\d+\\s*=\\s*\\d+)",
      "(\\bGROUP\\s+BY\\b.+\\bHAVING\\b)",
      "(\\bORDER\\s+BY\\b\\s+\\d+)",
      "(\\bEXEC\\b\\s*\\()",
      "(\\bEXECUTE\\b\\s*\\()",
      "('\\s*;)",
      "(\"\\s*;)",
      "(\\|\\|\\s*')",
      "(\\+\\s*')",
      "(')\\s*(\\+|\\|\\|)",
      "(%00)",
      "(\\x00)",
      "(EXTRACTVALUE\\s*\\()",
      "(UPDATEXML\\s*\\()",
      "(EXP\\s*\\(~)",
      "(GEOMETRYCOLLECTION\\s*\\()",
      "(MULTIPOINT\\s*\\()",
      "(POLYGON\\s*\\()",
      "(LINESTRING\\s*\\()",
      "(ROW\\s*\\()",
      "(procedure\\s+analyse)",
      "(handler\\s+.+\\s+open)",
      "(;\\s*DECLARE\\b)",
      "(;\\s*SET\\b)",
      "(\\binto\\s+(out|dump)file\\b)",
      "(\\bload\\s+data\\b.*\\binfile\\b)"
    ]
  },

