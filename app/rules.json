      "(<iframe[^>]*>)",
      "(<object[^>]*>)",
      "(<embed[^>]*>)",
      "(<svg[^>]*>)",
      "(<img[^>]*onerror)",
      "(<img[^>]*onload)",
      "(<body[^>]*onload)",
      "(<input[^>]*onfocus)",
      "(<marquee[^>]*>)",
      "(<bgsound[^>]*>)",
      "(<audio[^>]*>)",
      "(<video[^>]*>)",
      "(<source[^>]*>)",
      "(<applet[^>]*>)",
      "(<base[^>]*>)",
      "(<link[^>]*>)",
      "(<meta[^>]*http-equiv)",
      "(<style[^>]*>)",
      "(expression\\s*\\()",
