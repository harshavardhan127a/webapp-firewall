# ===========================================
# WAF Project .gitignore
# ===========================================

# Virtual environments
.venv/
venv/
env/
ENV/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg

# IDE/Editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# Runtime data
data/waf.db
data/*.db-journal
logs/
*.log

# Environment files (may contain secrets)
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker
docker-compose.override.yml

# Coverage reports
htmlcov/
.coverage
coverage.xml

# Test artifacts
.pytest_cache/
.tox/
