# WAF Configuration - Copy this to .env and customize
# =============================================================================

# General Settings
WAF_DEBUG=False
WAF_HOST=0.0.0.0
WAF_PORT=5000
WAF_BACKEND_URL=http://localhost:8082

# Dashboard Settings (REQUIRED for dashboard access)
WAF_DASHBOARD_PASSWORD=ChangeMe_SecurePassword123!
WAF_DASHBOARD_USERNAME=admin
WAF_DASHBOARD_SECRET_KEY=

# API Management Key (for /waf/* management endpoints)
WAF_API_KEY=your-api-key-here

# Rate Limiting
WAF_RATE_LIMIT_ENABLED=True
WAF_RATE_LIMIT_REQUESTS=100
WAF_RATE_LIMIT_WINDOW=60

# IP Blocking
WAF_BLOCK_DURATION=1800
WAF_PERMANENT_BLOCK_THRESHOLD=10

# Trusted Proxy Settings (enable if behind nginx/haproxy)
WAF_TRUST_PROXY_HEADERS=False
WAF_TRUSTED_PROXIES=

# Whitelist (comma-separated IPs or "NONE" to disable)
WAF_WHITELIST_IPS=NONE

# Security Modules
WAF_PROTECTION_SQLI=True
WAF_PROTECTION_XSS=True
WAF_PROTECTION_PATH_TRAVERSAL=True
WAF_PROTECTION_CMDI=True

# Detection Settings
WAF_PARANOIA_LEVEL=2
WAF_RISK_BLOCK_THRESHOLD=80
WAF_RISK_CHALLENGE_THRESHOLD=40
WAF_RISK_LOG_THRESHOLD=15

# Cache Settings
WAF_CACHE_ENABLED=True
WAF_CACHE_MAX_SIZE=10000
WAF_CACHE_TTL=300

# Anomaly Detection
WAF_ANOMALY_ENABLED=True
WAF_ANOMALY_USE_ISOLATION_FOREST=False
WAF_ANOMALY_THRESHOLD=70

# Geo-blocking (optional)
WAF_GEO_BLOCKING_ENABLED=False
WAF_GEO_BLOCKED_COUNTRIES=
WAF_GEO_ALLOWED_COUNTRIES=

# Storage Backend (memory, sqlite, redis)
WAF_STORAGE_BACKEND=sqlite
WAF_SQLITE_DB_PATH=./data/waf.db

# Redis Settings (if using redis backend)
WAF_REDIS_HOST=localhost
WAF_REDIS_PORT=6379
WAF_REDIS_DB=0
WAF_REDIS_PASSWORD=
